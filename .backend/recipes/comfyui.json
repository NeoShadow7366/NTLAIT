{
  "app_id": "comfyui",
  "name": "ComfyUI",
  "repository": "https://github.com/comfyanonymous/ComfyUI.git",
  "install_mode": "latest_release",
  "description": "Node-based visual workflow editor for Stable Diffusion and FLUX models.",
  "install_commands": [
    "pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121",
    "pip install -r requirements.txt"
  ],
  "model_symlinks": {
    "checkpoints": "models/checkpoints",
    "loras": "models/loras",
    "vaes": "models/vae",
    "controlnet": "models/controlnet",
    "unet": "models/unet",
    "clip": "models/clip",
    "embeddings": "models/embeddings"
  },
  "port": 8188,
  "launch_command": "main.py --port 8188 --preview-method auto"
}
